# Environment Variables for Growly Admin Web
# Copy this to .env.local and fill in the values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only - DO NOT expose to client!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin Configuration
# Comma-separated list of emails allowed to access admin
ADMIN_ALLOWED_EMAILS=admin@growly.id
