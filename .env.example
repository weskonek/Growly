# ============================================
# Growly Environment Variables Template
# Copy to .env.local for local development
# ============================================

# ============================================
# SUPABASE
# ============================================
# Get these from your Supabase project dashboard
# Settings > API

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# GEMINI API
# ============================================
# Get from Google AI Studio: https://aistudio.google.com/
# Edge Functions will use this to call Gemini

GEMINI_API_KEY=AIza...

# ============================================
# FLUTTER APPS (growly_core)
# ============================================
# These values are used by the Flutter apps
# Copy to packages/growly_core/lib/core/config/env.dart

AI_GATEWAY_URL=https://your-project-ref.supabase.co/functions/v1/ai-tutor

# ============================================
# ENVIRONMENT
# ============================================
# Node environment for Edge Functions
NODE_ENV=development

# ============================================
# ANALYTICS (optional)
# ============================================
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ============================================
# PUSH NOTIFICATIONS (optional)
# ============================================
# FCM server key (for Android)
# FCM_SERVER_KEY=

# ============================================
# NOTES
# ============================================
# 1. Never commit .env.local to git!
# 2. Use different Supabase projects for dev/staging/prod
# 3. Supabase CLI: supabase link --project-ref <ref>
# 4. Apply migrations: supabase db push