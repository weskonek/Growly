# ============================================
# SUPABASE
# ============================================
# Get these from your Supabase project dashboard
# Settings > API

SUPABASE_URL=https://scfgcegyvgkxntqmmerl.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNjZmdjZWd5dmdreG50cW1tZXJsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzcyOTUwMDksImV4cCI6MjA5Mjg3MTAwOX0.BP7E05P1ARVSdLz_UH0BSlL9k309bOD_MipXFHbTQPY
# SERVICE_ROLE_KEY should be kept secret - set via GitHub Secrets for CI/CD
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# GEMINI API
# ============================================
# Get from Google AI Studio: https://aistudio.google.com/
# Edge Functions will use this to call Gemini

GEMINI_API_KEY=AIza...

# ============================================
# FLUTTER APPS (growly_core)
# ============================================
# These values are used by the Flutter apps
# Copy to packages/growly_core/lib/core/config/env.dart

AI_GATEWAY_URL=https://scfgcegyvgkxntqmmerl.supabase.co/functions/v1/ai-tutor

# ============================================
# ENVIRONMENT
# ============================================
# Node environment for Edge Functions
NODE_ENV=development

# ============================================
# ANALYTICS (optional)
# ============================================
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ============================================
# PUSH NOTIFICATIONS (optional)
# ============================================
# FCM server key (for Android)
# FCM_SERVER_KEY=

# ============================================
# NOTES
# ============================================
# 1. Never commit .env.local to git!
# 2. Use different Supabase projects for dev/staging/prod
# 3. Supabase CLI: supabase link --project-ref <ref>
# 4. Apply migrations: supabase db push